{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const s=require('fs').readFileSync(0,'utf8');const d=JSON.parse(s);const f=d.tool_input&&d.tool_input.file_path;if(f){require('child_process').execSync('npx prettier --write '+JSON.stringify(f)+' --ignore-unknown',{stdio:'inherit'})}\" 2>/dev/null || true",
            "statusMessage": "Formatting with prettier..."
          }
        ]
      }
    ]
    // "Notification": [
    //   {
    //     "matcher": "",
    //     "hooks": [
